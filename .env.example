# Copy to platform environment variables (Vercel / Netlify). Do not commit real secrets.

# --- Claude AI assistant (/api/claude) ---
CLAUDE_API_KEY=
# Optional: provider-specific model slug.
CLAUDE_MODEL=

# --- Lead capture (/api/lead, via Resend) ---
RESEND_API_KEY=
# Where lead notifications are sent, e.g. shek0913@tbchk.com
LEAD_NOTIFY_TO=
# Sender address — MUST be a Resend-verified domain/sender, e.g. hello@tbchk.com
LEAD_FROM=

# --- Gated resource lead storage (/api/leads/base, via Google Sheets) ---
GOOGLE_SHEETS_CLIENT_EMAIL=
# In Vercel, paste the service-account private key with escaped newlines (\n).
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_BASE_LEADS_SPREADSHEET_ID=
# Optional. Sheet tab/range must contain columns:
# created_at, email, source, resource_slug, resource_title, page_url, user_agent, status
GOOGLE_SHEETS_BASE_LEADS_RANGE=base_leads!A:H
