# Copy to platform environment variables (Vercel / Netlify). Do not commit real secrets.

# --- Claude AI assistant (/api/claude) ---
CLAUDE_API_KEY=
# Optional: provider-specific model slug.
CLAUDE_MODEL=

# --- Lead capture (/api/lead, via Resend) ---
RESEND_API_KEY=
# Where lead notifications are sent, e.g. shek0913@tbchk.com
LEAD_NOTIFY_TO=
# Sender address — MUST be a Resend-verified domain/sender, e.g. hello@tbchk.com
LEAD_FROM=

# --- Gated resource lead storage (/api/leads/base, via Google Apps Script webhook) ---
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=
